# Notion Integration
NOTION_API_KEY=secret_xxx
NOTION_HABITS_DB_ID=xxx
NOTION_COMPLETIONS_DB_ID=xxx
NOTION_EVENTS_DB_ID=xxx
NOTION_SKIPS_DB_ID=xxx

# App config (edit these, then redeploy to change)
TIMEZONE=Asia/Kolkata
WEEK_START_DAY=1
DEADLINE_SURFACE_DAYS=3

# Security
APP_PASSPHRASE=your-passphrase-here
COOKIE_SECRET=replace-with-random-32-char-string
